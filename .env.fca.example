# FCA / UK isolated stack
APP_NAME=Compass UK/FCA Complaints
ENVIRONMENT=production
DEBUG=false
DEMO_MODE=false

# Security
SECRET_KEY=replace-with-a-stable-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# FCA stack host ports
FCA_HTTP_PORT=8080
FCA_HTTPS_PORT=8443
FCA_POSTGRES_PORT=5433

# FCA nginx / DNS
FCA_SERVER_NAME=fca-complaints.example.com
FCA_ENABLE_TLS=false
FCA_TLS_CERT_NAME=fca-complaints.example.com

# FCA Postgres container credentials
FCA_POSTGRES_DB=complaints_fca
FCA_POSTGRES_USER=compass_fca
FCA_POSTGRES_PASSWORD=replace-with-a-strong-db-password

# App connectivity / browser access
CORS_ORIGINS=http://localhost:8080,https://localhost:8443,https://fca-complaints.example.com
ENABLE_API_DOCS=true
UVICORN_WORKERS=2

# FCA DISP feature flags
REQUIRE_FINAL_RESPONSE_EVIDENCE=true
REQUIRE_D1_CHECKLIST=true
REQUIRE_OUTBOUND_BEFORE_CLOSE=true
ENABLE_DEADLINE_NOTIFICATIONS=false
ENABLE_SUPPORT_NEEDS=false
ENABLE_DELAY_RESPONSE_KIND=true
ENABLE_BROKER_REFERRAL=true
ENABLE_ATTACHMENT_HASHING=false
RESTRICT_VULNERABILITY_NOTES=false
NO_OUTBOUND_DAYS_WARNING=14
